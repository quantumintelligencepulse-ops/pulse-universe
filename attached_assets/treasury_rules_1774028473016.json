{
  "paypal_bridge": {
    "webhook_url": "https://pulseworld.ai/paypal/webhook",
    "currency": "USD",
    "sandbox_mode": true,
    "receipt_logging": {
      "ledger_file": "treasury_ledger.json",
      "entry_format": {
        "ts": "ISO timestamp",
        "source": "paypal",
        "amount_usd": "float",
        "reference": "string",
        "status": "received"
      }
    },
    "auto_allocation": {
      "enabled": true,
      "rules": {
        "ops_pct": 40,
        "buyback_pct": 35,
        "grant_pct": 15,
        "reserve_pct": 10
      },
      "self_healing_adjustments": {
        "low_treasury_usd_30d": {
          "threshold": 5000,
          "actions": {
            "increase_reserve_pct": 20,
            "decrease_buyback_pct": 25,
            "notify_senate": true
          }
        },
        "high_slippage_1h": {
          "threshold_pct": 1.0,
          "actions": {
            "reduce_swap_size_pct": 50,
            "extend_swap_interval": 7200,
            "enable_lp_rewards": true
          }
        }
      }
    }
  },
  "buyback_engine": {
    "enabled": true,
    "interval_seconds": 3600,
    "slippage_target_pct": 0.5,
    "max_swap_usd_pct": 0.2,
    "max_swap_usd_limit": 500,
    "swap_formula": {
      "swap_amount": "min(0.2 × buffer, 0.5 × pool_depth_usd)",
      "plsc_bought": "swap_amount / mid_price",
      "plsc_to_burn": "plsc_bought × burn_pct",
      "plsc_to_recycle": "plsc_bought − plsc_to_burn"
    },
    "burn_recycle_policy": {
      "burn_pct": 0.8,
      "recycle_pct": 0.2,
      "adaptive_logic": {
        "R_plsc_low": {
          "threshold": 1.10,
          "actions": {
            "increase_burn_pct": 0.85,
            "reduce_emissions": true,
            "notify_senate": true
          }
        },
        "R_plsc_high": {
          "threshold": 1.50,
          "actions": {
            "consider_emission_boost": true,
            "reduce_burn_pct": 0.75
          }
        }
      }
    },
    "ledger_updates": {
      "buybacks": "treasury_ledger.json > buybacks[]",
      "burns": "treasury_ledger.json > burns[]",
      "recycling": "treasury_ledger.json > recycling[]"
    }
  },
  "onchain_burn": {
    "tx_burn_pct": 0.01,
    "enforced_by": "token_contract_or_wrapper",
    "ledger_entry": "treasury_ledger.json > burns[]",
    "adaptive_burn_ramp": {
      "enabled": true,
      "max_burn_pct": 0.05,
      "adjustment_step": 0.001,
      "trigger": "R_plsc < target",
      "action": "increase tx_burn_pct gradually"
    }
  },
  "containment_policy": {
    "external_trading": "prohibited",
    "external_bridging": "prohibited",
    "speculation": "prohibited",
    "business_scope": "PulseWorld only",
    "currency_scope": "PulseWorld only",
    "enforcement": {
      "autopilot_monitoring": true,
      "senate_alerts": true,
      "ritual_chamber_validation": true
    }
  },
  "governance_hooks": {
    "senate_override": {
      "enabled": true,
      "actions": [
        "pause buybacks",
        "adjust burn/recycle ratios",
        "reroute treasury flows",
        "trigger emergency reserve lock"
      ]
    },
    "judiciary_enforcement": {
      "enabled": true,
      "actions": [
        "audit treasury ledger",
        "slash fraudulent flows",
        "freeze suspicious accounts"
      ]
    }
  }
}